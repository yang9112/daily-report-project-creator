{
  "name": "daily-report-project-creator",
  "version": "1.0.0",
  "description": "将现有的技术博客日报技能打包成开源项目的完整工具",
  "main": "scripts/create-project.js",
  "bin": {
    "daily-report-create": "scripts/create-project.js",
    "daily-report-batch": "scripts/batch-create.js",
    "theme-preview": "scripts/theme-preview.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint scripts/ tests/ --fix",
    "validate": "node scripts/validate.js",
    "create": "node scripts/create-project.js",
    "batch": "node scripts/batch-create.js",
    "theme": "node scripts/theme-preview.js",
    "example": "node scripts/batch-create.js config",
    "precommit": "npm run lint && npm run test",
    "posttest": "npm run validate"
  },
  "keywords": [
    "daily-report",
    "tech-blog",
    "ai-summary",
    "automation",
    "github",
    "project-creator",
    "cli-tool",
    "skill-packaging"
  ],
  "author": "大白 <dabai@openclaw.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yang9112/daily-report-project-creator"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "commander": "^11.1.0",
    "yargs": "^18.0.0",
    "inquirer": "^8.2.6",
    "fs-extra": "^11.2.0",
    "chalk": "^4.1.2",
    "simple-git": "^3.23.0",
    "semver": "^7.6.2",
    "nodemailer": "^8.0.1",
    "yaml": "^2.4.2",
    "dotenv": "^16.4.5",
    "ora": "^5.4.1",
    "express": "^4.18.2",
    "ejs": "^3.1.9"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-promise": "^6.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "type": "commonjs"
}