{
  "name": "daily-report-project-creator",
  "version": "1.0.0",
  "description": "将现有的技术博客日报技能打包成开源项目的完整工具",
  "main": "scripts/create-project.js",
  "bin": {
    "daily-report-create": "scripts/create-project.js",
    "daily-report-batch": "scripts/batch-create.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint scripts/ tests/ --fix",
    "validate": "node scripts/validate.js",
    "create": "node scripts/create-project.js",
    "batch": "node scripts/batch-create.js",
    "example": "node scripts/batch-create.js config",
    "precommit": "npm run lint && npm run test",
    "posttest": "npm run validate"
  },
  "keywords": [
    "daily-report",
    "tech-blog",
    "ai-summary",
    "automation",
    "github",
    "project-creator",
    "cli-tool",
    "skill-packaging"
  ],
  "author": "大白 <dabai@openclaw.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yang9112/daily-report-project-creator"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "commander": "^11.0.0",
    "eslint": "^8.55.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.0",
    "inquirer": "^9.2.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "eslintConfig": {
    "extends": "standard",
    "env": {
      "node": true,
      "jest": true
    },
    "rules": {
      "no-console": "off",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "type": "commonjs"
}
