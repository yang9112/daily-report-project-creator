{
  "testEnvironment": "node",
  "verbose": false,
  "silent": false,
  "errorOnDeprecated": true,
  "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
  "testMatch": [
    "<rootDir>/tests/**/*.test.js"
  ],
  "collectCoverage": false,
  "collectCoverageFrom": [
    "scripts/**/*.js",
    "!scripts/test.js",
    "!**/node_modules/**"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": [
    "text",
    "lcov",
    "html"
  ],
  "testTimeout": 30000,
  "reporters": [
    ["default", { "verbose": false }]
  ]
}