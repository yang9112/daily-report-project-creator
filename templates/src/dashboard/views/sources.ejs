<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f5f7fa;
      color: #333;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    header {
      background: #fff;
      padding: 20px 0;
      border-bottom: 1px solid #e4e7ed;
      margin-bottom: 30px;
    }
    header h1 {
      font-size: 24px;
      color: #409eff;
    }
    .section {
      background: #fff;
      border-radius: 8px;
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
    .section h2 {
      font-size: 18px;
      margin-bottom: 20px;
      color: #303133;
    }
    .sources-table {
      width: 100%;
      border-collapse: collapse;
    }
    .sources-table th,
    .sources-table td {
      padding: 12px;
      text-align: left;
      border-bottom: 1px solid #ebeef5;
    }
    .sources-table th {
      background: #f5f7fa;
      color: #606266;
      font-weight: 600;
    }
    .sources-table tr:hover {
      background: #f5f7fa;
    }
    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 12px;
    }
    .status-badge.active {
      background: #f0f9ff;
      color: #409eff;
    }
    .status-badge.inactive {
      background: #f4f4f5;
      color: #909399;
    }
    .category-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 12px;
      background: #ecf5ff;
      color: #409eff;
    }
    .nav {
      display: flex;
      gap: 20px;
      margin-bottom: 20px;
    }
    .nav a {
      color: #606266;
      text-decoration: none;
      padding: 8px 16px;
      border-radius: 4px;
    }
    .nav a:hover, .nav a.active {
      background: #409eff;
      color: #fff;
    }
    .summary-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 24px;
    }
    .summary-stat {
      background: #f5f7fa;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
    }
    .summary-stat .value {
      font-size: 32px;
      font-weight: 600;
      color: #409eff;
    }
    .summary-stat .label {
      font-size: 14px;
      color: #909399;
    }
    .empty {
      text-align: center;
      padding: 60px 20px;
      color: #909399;
    }
    .footer {
      text-align: center;
      padding: 20px;
      color: #909399;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <h1>📡 RSS源管理</h1>
    </div>
  </header>

  <div class="container">
    <nav class="nav">
      <a href="/">概览</a>
      <a href="/reports">日报列表</a>
      <a href="/sources" class="active">RSS源</a>
    </nav>

    <div class="section">
      <h2>📊 源统计</h2>
      <% if (sources && sources.length > 0) { %>
        <div class="summary-stats">
          <div class="summary-stat">
            <div class="value"><%= sources.length %></div>
            <div class="label">总源数</div>
          </div>
          <div class="summary-stat">
            <div class="value"><%= sources.filter(s => s.is_active).length %></div>
            <div class="label">活跃源</div>
          </div>
          <div class="summary-stat">
            <div class="value"><%= sources.filter(s => !s.is_active).length %></div>
            <div class="label">未激活</div>
          </div>
        </div>
      <% } %>
    </div>

    <div class="section">
      <h2>📋 源列表</h2>

      <% if (sources && sources.length > 0) { %>
        <table class="sources-table">
          <thead>
            <tr>
              <th>名称</th>
              <th>分类</th>
              <th>URL</th>
              <th>状态</th>
            </tr>
          </thead>
          <tbody>
            <% sources.forEach(source => { %>
              <tr>
                <td><%= source.name %></td>
                <td>
                  <% if (source.category) { %>
                    <span class="category-badge"><%= source.category %></span>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td>
                  <a href="<%= source.url %>" target="_blank" style="color: #409eff; text-decoration: none;">
                    <%= source.url.substring(0, 50) %>...
                  </a>
                </td>
                <td>
                  <span class="status-badge <%= source.is_active ? 'active' : 'inactive' %>">
                    <%= source.is_active ? '活跃' : '未激活' %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty">
          <p>暂无RSS源配置</p>
          <p>请在 config/sources.json 中添加RSS源</p>
        </div>
      <% } %>
    </div>
  </div>

  <div class="footer">
    <p>技术日报系统 · <%= new Date().toLocaleString('zh-CN') %></p>
  </div>
</body>
</html>