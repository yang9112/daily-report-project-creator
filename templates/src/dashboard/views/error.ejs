<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f5f7fa;
      color: #333;
    }
    .container {
      max-width: 600px;
      margin: 100px auto;
      padding: 20px;
      text-align: center;
    }
    .error-box {
      background: #fff;
      border-radius: 8px;
      padding: 40px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
    .error-box h1 {
      font-size: 48px;
      color: #f56c6c;
      margin-bottom: 20px;
    }
    .error-box h2 {
      font-size: 24px;
      color: #303133;
      margin-bottom: 16px;
    }
    .error-box p {
      color: #606266;
      margin-bottom: 24px;
    }
    .error-box a {
      color: #409eff;
      text-decoration: none;
    }
    .error-box a:hover {
      text-decoration: underline;
    }
    .error-details {
      background: #fef0f0;
      border: 1px solid #fde2e2;
      border-radius: 4px;
      padding: 16px;
      margin: 20px 0;
      text-align: left;
      font-family: monospace;
      font-size: 12px;
      color: #f56c6c;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="error-box">
      <h1>⚠️</h1>
      <h2>出错了</h2>
      <% if (error) { %>
        <div class="error-details"><%= error %></div>
      <% } %>
      <p>
        <a href="/">返回首页</a>
      </p>
    </div>
  </div>
</body>
</html>