<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f5f7fa;
      color: #333;
      line-height: 1.6;
    }
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 20px;
    }
    header {
      background: #fff;
      padding: 20px 0;
      border-bottom: 1px solid #e4e7ed;
      margin-bottom: 30px;
    }
    header h1 {
      font-size: 24px;
      color: #409eff;
    }
    .section {
      background: #fff;
      border-radius: 8px;
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
    .report-header {
      border-bottom: 2px solid #409eff;
      padding-bottom: 16px;
      margin-bottom: 24px;
    }
    .report-header h2 {
      font-size: 24px;
      color: #303133;
      margin-bottom: 8px;
    }
    .report-header .meta {
      font-size: 14px;
      color: #909399;
    }
    .report-stats {
      display: flex;
      gap: 24px;
      margin-bottom: 24px;
      padding: 16px;
      background: #f5f7fa;
      border-radius: 8px;
    }
    .report-stats .stat {
      text-align: center;
    }
    .report-stats .stat .value {
      font-size: 24px;
      font-weight: 600;
      color: #409eff;
    }
    .report-stats .stat .label {
      font-size: 12px;
      color: #909399;
    }
    .report-content {
      line-height: 1.8;
    }
    .report-content h3 {
      color: #303133;
      margin: 24px 0 12px;
      font-size: 18px;
    }
    .report-content h4 {
      color: #606266;
      margin: 20px 0 8px;
      font-size: 16px;
    }
    .report-content ul {
      margin: 12px 0;
      padding-left: 24px;
    }
    .report-content li {
      margin: 8px 0;
    }
    .report-content a {
      color: #409eff;
      text-decoration: none;
    }
    .report-content a:hover {
      text-decoration: underline;
    }
    .featured-article {
      padding: 16px;
      background: #f0f9ff;
      border-left: 4px solid #409eff;
      margin: 16px 0;
      border-radius: 0 8px 8px 0;
    }
    .featured-article .title {
      font-weight: 600;
      color: #303133;
      margin-bottom: 8px;
    }
    .featured-article .summary {
      color: #606266;
      font-size: 14px;
    }
    .nav {
      display: flex;
      gap: 20px;
      margin-bottom: 20px;
    }
    .nav a {
      color: #606266;
      text-decoration: none;
      padding: 8px 16px;
      border-radius: 4px;
    }
    .nav a:hover, .nav a.active {
      background: #409eff;
      color: #fff;
    }
    .back-link {
      display: inline-block;
      margin-bottom: 20px;
      color: #409eff;
      text-decoration: none;
    }
    .back-link:hover {
      text-decoration: underline;
    }
    .error {
      background: #fef0f0;
      border: 1px solid #fde2e2;
      color: #f56c6c;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
    }
    .footer {
      text-align: center;
      padding: 20px;
      color: #909399;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <h1>📄 报告详情</h1>
    </div>
  </header>

  <div class="container">
    <nav class="nav">
      <a href="/">概览</a>
      <a href="/reports">日报列表</a>
      <a href="/sources">RSS源</a>
    </nav>

    <a href="/reports" class="back-link">← 返回日报列表</a>

    <% if (report) { %>
      <div class="section">
        <div class="report-header">
          <h2>📅 <%= report.report_date %></h2>
          <div class="meta">
            生成时间: <%= report.generated_at ? new Date(report.generated_at).toLocaleString('zh-CN') : '未知' %>
          </div>
        </div>

        <div class="report-stats">
          <div class="stat">
            <div class="value"><%= report.total_articles || 0 %></div>
            <div class="label">文章总数</div>
          </div>
          <div class="stat">
            <div class="value"><%= report.featured_articles || 0 %></div>
            <div class="label">精选文章</div>
          </div>
        </div>

        <% if (report.content) { %>
          <div class="report-content">
            <%- report.content %>
          </div>
        <% } else { %>
          <div class="report-content">
            <p>暂无报告内容</p>
            <p>报告文件: <%= report.file_path || '无' %></p>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="section">
        <div class="error">
          <h3>❌ 报告不存在</h3>
          <p>请返回日报列表查看可用的报告</p>
        </div>
      </div>
    <% } %>
  </div>

  <div class="footer">
    <p>技术日报系统 · <%= new Date().toLocaleString('zh-CN') %></p>
  </div>
</body>
</html>