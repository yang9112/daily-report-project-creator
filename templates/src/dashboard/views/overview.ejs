<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f5f7fa;
      color: #333;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    header {
      background: #fff;
      padding: 20px 0;
      border-bottom: 1px solid #e4e7ed;
      margin-bottom: 30px;
    }
    header h1 {
      font-size: 24px;
      color: #409eff;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }
    .stat-card {
      background: #fff;
      border-radius: 8px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
    .stat-card h3 {
      font-size: 14px;
      color: #909399;
      margin-bottom: 12px;
    }
    .stat-card .value {
      font-size: 32px;
      font-weight: 600;
      color: #303133;
    }
    .stat-card .label {
      font-size: 12px;
      color: #909399;
      margin-top: 8px;
    }
    .section {
      background: #fff;
      border-radius: 8px;
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
    .section h2 {
      font-size: 18px;
      margin-bottom: 20px;
      color: #303133;
    }
    .task-status {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .task-item {
      padding: 16px;
      border-radius: 6px;
      background: #f5f7fa;
    }
    .task-item h4 {
      font-size: 14px;
      margin-bottom: 8px;
    }
    .task-item .progress {
      height: 8px;
      background: #e4e7ed;
      border-radius: 4px;
      overflow: hidden;
      margin-top: 8px;
    }
    .task-item .progress-bar {
      height: 100%;
      background: #67c23a;
      border-radius: 4px;
    }
    .task-item .progress-bar.warning {
      background: #e6a23c;
    }
    .task-item .progress-bar.danger {
      background: #f56c6c;
    }
    .reports-list {
      list-style: none;
    }
    .reports-list li {
      padding: 12px 0;
      border-bottom: 1px solid #ebeef5;
    }
    .reports-list li:last-child {
      border-bottom: none;
    }
    .reports-list a {
      color: #409eff;
      text-decoration: none;
    }
    .reports-list a:hover {
      text-decoration: underline;
    }
    .source-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
    }
    .source-item {
      padding: 12px;
      border-radius: 6px;
      background: #f5f7fa;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .source-item .status {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #67c23a;
    }
    .source-item .status.inactive {
      background: #909399;
    }
    .nav {
      display: flex;
      gap: 20px;
      margin-bottom: 20px;
    }
    .nav a {
      color: #606266;
      text-decoration: none;
      padding: 8px 16px;
      border-radius: 4px;
    }
    .nav a:hover, .nav a.active {
      background: #409eff;
      color: #fff;
    }
    .footer {
      text-align: center;
      padding: 20px;
      color: #909399;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <h1>📊 技术日报控制台</h1>
    </div>
  </header>

  <div class="container">
    <nav class="nav">
      <a href="/" class="active">概览</a>
      <a href="/reports">日报列表</a>
      <a href="/sources">RSS源</a>
    </nav>

    <div class="stats-grid">
      <div class="stat-card">
        <h3>📰 文章总数</h3>
        <div class="value"><%= stats.totalArticles || 0 %></div>
        <div class="label">最近7天采集</div>
      </div>
      <div class="stat-card">
        <h3>✨ 精选文章</h3>
        <div class="value"><%= stats.featuredArticles || 0 %></div>
        <div class="label">AI推荐文章</div>
      </div>
      <div class="stat-card">
        <h3>📑 报告总数</h3>
        <div class="value"><%= stats.totalReports || 0 %></div>
        <div class="label">已生成日报</div>
      </div>
      <div class="stat-card">
        <h3>📡 RSS源</h3>
        <div class="value"><%= sourceStats.total || 0 %></div>
        <div class="label">活跃: <%= sourceStats.active || 0 %></div>
      </div>
    </div>

    <div class="section">
      <h2>📈 任务完成进度</h2>
      <div class="task-status">
        <div class="task-item">
          <h4>📥 采集任务</h4>
          <div class="value"><%= sourceStats.active || 0 %>/<%= sourceStats.total || 0 %></div>
          <div class="progress">
            <div class="progress-bar" style="width: <%= sourceStats.total ? (sourceStats.active / sourceStats.total * 100) : 0 %>%"></div>
          </div>
        </div>
        <div class="task-item">
          <h4>🔄 处理任务</h4>
          <div class="value"><%= stats.processedArticles || 0 %>/<%= stats.totalArticles || 0 %></div>
          <div class="progress">
            <div class="progress-bar <%= stats.totalArticles > 0 && (stats.processedArticles / stats.totalArticles) < 0.5 ? 'warning' : '' %>" style="width: <%= stats.totalArticles ? (stats.processedArticles / stats.totalArticles * 100) : 0 %>%"></div>
          </div>
        </div>
        <div class="task-item">
          <h4>📝 生成任务</h4>
          <div class="value"><%= stats.totalReports || 0 %></div>
          <div class="label">最近: <%= stats.lastReportDate || '无' %></div>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>📋 最近日报</h2>
      <% if (recentReports && recentReports.length > 0) { %>
        <ul class="reports-list">
          <% recentReports.forEach(report => { %>
            <li>
              <a href="/reports/<%= report.id %>">
                📑 <%= report.report_date %> - <%= report.total_articles || 0 %>篇文章, <%= report.featured_articles || 0 %>篇精选
              </a>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p style="color: #909399;">暂无生成的日报</p>
      <% } %>
      <div style="margin-top: 16px;">
        <a href="/reports" style="color: #409eff;">查看全部日报 →</a>
      </div>
    </div>

    <div class="section">
      <h2>📡 RSS源状态</h2>
      <% if (sourceStats.sources && sourceStats.sources.length > 0) { %>
        <div class="source-list">
          <% sourceStats.sources.forEach(source => { %>
            <div class="source-item">
              <span><%= source.name %></span>
              <span class="status <%= source.is_active ? '' : 'inactive' %>"></span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p style="color: #909399;">暂无RSS源配置</p>
      <% } %>
      <div style="margin-top: 16px;">
        <a href="/sources" style="color: #409eff;">管理RSS源 →</a>
      </div>
    </div>
  </div>

  <div class="footer">
    <p>技术日报系统 · <%= new Date().toLocaleString('zh-CN') %></p>
  </div>
</body>
</html>