<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f5f7fa;
      color: #333;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    header {
      background: #fff;
      padding: 20px 0;
      border-bottom: 1px solid #e4e7ed;
      margin-bottom: 30px;
    }
    header h1 {
      font-size: 24px;
      color: #409eff;
    }
    .section {
      background: #fff;
      border-radius: 8px;
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
    .section h2 {
      font-size: 18px;
      margin-bottom: 20px;
      color: #303133;
    }
    .reports-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
    }
    .report-card {
      border: 1px solid #ebeef5;
      border-radius: 8px;
      padding: 20px;
      transition: box-shadow 0.3s;
    }
    .report-card:hover {
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }
    .report-card h3 {
      font-size: 16px;
      margin-bottom: 12px;
      color: #409eff;
    }
    .report-card .meta {
      font-size: 12px;
      color: #909399;
      margin-bottom: 12px;
    }
    .report-card .stats {
      display: flex;
      gap: 16px;
      font-size: 14px;
      color: #606266;
    }
    .report-card .stats span {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .report-card .actions {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid #ebeef5;
    }
    .report-card .actions a {
      color: #409eff;
      text-decoration: none;
      font-size: 14px;
    }
    .report-card .actions a:hover {
      text-decoration: underline;
    }
    .pagination {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 30px;
    }
    .pagination a, .pagination span {
      padding: 8px 16px;
      border-radius: 4px;
      text-decoration: none;
      color: #606266;
      background: #fff;
      border: 1px solid #ebeef5;
    }
    .pagination a:hover {
      background: #409eff;
      color: #fff;
      border-color: #409eff;
    }
    .pagination .active {
      background: #409eff;
      color: #fff;
      border-color: #409eff;
    }
    .nav {
      display: flex;
      gap: 20px;
      margin-bottom: 20px;
    }
    .nav a {
      color: #606266;
      text-decoration: none;
      padding: 8px 16px;
      border-radius: 4px;
    }
    .nav a:hover, .nav a.active {
      background: #409eff;
      color: #fff;
    }
    .empty {
      text-align: center;
      padding: 60px 20px;
      color: #909399;
    }
    .empty p {
      margin-bottom: 16px;
    }
    .footer {
      text-align: center;
      padding: 20px;
      color: #909399;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <h1>📋 日报列表</h1>
    </div>
  </header>

  <div class="container">
    <nav class="nav">
      <a href="/">概览</a>
      <a href="/reports" class="active">日报列表</a>
      <a href="/sources">RSS源</a>
    </nav>

    <div class="section">
      <h2>📑 所有日报 (<%= pagination ? pagination.total : 0 %>)</h2>

      <% if (reports && reports.length > 0) { %>
        <div class="reports-grid">
          <% reports.forEach(report => { %>
            <div class="report-card">
              <h3>📅 <%= report.report_date %></h3>
              <div class="meta">
                生成时间: <%= report.generated_at ? new Date(report.generated_at).toLocaleString('zh-CN') : '未知' %>
              </div>
              <div class="stats">
                <span>📰 <%= report.total_articles || 0 %>篇文章</span>
                <span>✨ <%= report.featured_articles || 0 %>篇精选</span>
              </div>
              <div class="actions">
                <a href="/reports/<%= report.id %>">查看详情 →</a>
              </div>
            </div>
          <% }) %>
        </div>

        <% if (pagination && pagination.totalPages > 1) { %>
          <div class="pagination">
            <% if (page > 1) { %>
              <a href="?page=<%= page - 1 %>&limit=<%= limit %>">上一页</a>
            <% } %>

            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
              <% if (i === page) { %>
                <span class="active"><%= i %></span>
              <% } else if (i === 1 || i === pagination.totalPages || (i >= page - 1 && i <= page + 1)) { %>
                <a href="?page=<%= i %>&limit=<%= limit %>"><%= i %></a>
              <% } else if (i === page - 2 || i === page + 2) { %>
                <span>...</span>
              <% } %>
            <% } %>

            <% if (page < pagination.totalPages) { %>
              <a href="?page=<%= page + 1 %>&limit=<%= limit %>">下一页</a>
            <% } %>
          </div>
        <% } %>
      <% } else { %>
        <div class="empty">
          <p>暂无生成的日报</p>
          <p>请先运行采集和处理任务生成日报</p>
        </div>
      <% } %>
    </div>
  </div>

  <div class="footer">
    <p>技术日报系统 · <%= new Date().toLocaleString('zh-CN') %></p>
  </div>
</body>
</html>